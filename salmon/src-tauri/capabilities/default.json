{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the SalmonApp main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-confirm",
    "notification:default",
    "clipboard-manager:allow-read-image"
  ]
}
