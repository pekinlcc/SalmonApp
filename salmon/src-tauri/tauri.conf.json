{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SalmonApp",
  "version": "1.8.1",
  "identifier": "app.salmonapp.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SalmonApp",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "SalmonApp — local AI command center",
    "longDescription": "SalmonApp is a local AI command center for coding, mail, calendar, contacts, and tasks. It drives your locally logged-in Claude Code or Codex CLI, connects to Gmail / Outlook through desktop OAuth, and turns project plus inbox context into actionable briefings. Model credentials stay with the CLI; workspace data stays local. Linux (deb / AppImage / rpm) and macOS (dmg).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": null,
      "exceptionDomain": null
    }
  },
  "plugins": {}
}
