{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SalmonApp Desktop",
  "version": "2.0.37",
  "identifier": "app.salmonapp.desktopshell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "shell",
        "title": "SalmonApp Desktop",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "deb",
    "category": "DeveloperTool",
    "shortDescription": "SalmonApp Desktop — Ubuntu-style shell (Linux only)",
    "longDescription": "SalmonApp Desktop is the Linux-only desktop-shell variant of SalmonApp. It installs a labwc-backed Wayland session that renders the AI Brief widget + dock + launcher as the desktop shell, with the same Mail / Calendar / Tasks / Contacts data the regular SalmonApp uses.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["labwc", "xwayland", "foot", "wlrctl", "wlr-randr", "waybar", "libappindicator3-1", "swaylock", "brightnessctl", "gammastep", "playerctl", "power-profiles-daemon", "xdg-utils", "xdg-user-dirs", "xdg-desktop-portal", "xdg-desktop-portal-wlr", "xdg-desktop-portal-gtk", "dbus-bin", "fcitx5 | ibus", "fcitx5-config-qt | ibus", "wireplumber", "pulseaudio-utils", "pavucontrol | gnome-control-center", "gnome-control-center | systemsettings | xfce4-settings | lxqt-config", "wl-clipboard", "cliphist", "libglib2.0-bin", "libgtk-3-bin", "gsettings-desktop-schemas", "fontconfig", "trash-cli", "mako | dunst", "policykit-1-gnome | lxpolkit | mate-polkit", "swaybg", "swayidle", "wlopm", "kanshi", "procps", "wdisplays | gnome-control-center | arandr", "grim", "slurp", "libnotify-bin", "util-linux", "udisks2", "udiskie", "bluez", "blueman | gnome-control-center", "network-manager", "network-manager-gnome | gnome-control-center", "cups-client", "system-config-printer | gnome-control-center"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": null,
      "exceptionDomain": null
    }
  },
  "plugins": {}
}
