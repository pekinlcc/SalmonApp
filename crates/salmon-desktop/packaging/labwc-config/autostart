#!/bin/sh

systemctl --user import-environment PATH DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE DESKTOP_SESSION DBUS_SESSION_BUS_ADDRESS GTK_IM_MODULE QT_IM_MODULE XMODIFIERS XDG_DATA_DIRS XDG_CONFIG_DIRS GDK_SCALE GDK_DPI_SCALE QT_SCALE_FACTOR XCURSOR_SIZE 2>/dev/null || true
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment --systemd PATH DISPLAY WAYLAND_DISPLAY \
    XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE DESKTOP_SESSION \
    DBUS_SESSION_BUS_ADDRESS GTK_IM_MODULE QT_IM_MODULE XMODIFIERS \
    XDG_DATA_DIRS XDG_CONFIG_DIRS GDK_SCALE GDK_DPI_SCALE QT_SCALE_FACTOR XCURSOR_SIZE 2>/dev/null || true
fi

process_running() {
  command -v pgrep >/dev/null 2>&1 && pgrep -x "$1" >/dev/null 2>&1
}

process_running_f() {
  command -v pgrep >/dev/null 2>&1 && pgrep -f "$1" >/dev/null 2>&1
}

polkit_agent_running() {
  process_running_f polkit-gnome-authentication-agent-1 ||
    process_running lxpolkit ||
    process_running mate-polkit
}

im_env="${GTK_IM_MODULE:-}:${QT_IM_MODULE:-}:${XMODIFIERS:-}"
if [ "${im_env#*fcitx}" != "$im_env" ] &&
  command -v fcitx5 >/dev/null 2>&1 &&
  ! process_running fcitx5; then
  fcitx5 -d >/dev/null 2>&1 || true
elif [ "${im_env#*ibus}" != "$im_env" ] &&
  command -v ibus-daemon >/dev/null 2>&1 &&
  ! process_running ibus-daemon; then
  ibus-daemon -drx >/dev/null 2>&1 || true
fi

if command -v swaybg >/dev/null 2>&1 && ! process_running swaybg; then
  swaybg -c 111111 >/dev/null 2>&1 &
fi

if command -v wl-paste >/dev/null 2>&1 &&
  command -v cliphist >/dev/null 2>&1 &&
  ! process_running_f 'wl-paste.*cliphist store'; then
  wl-paste --watch cliphist store >/dev/null 2>&1 &
elif command -v wl-paste >/dev/null 2>&1 &&
  command -v clipman >/dev/null 2>&1 &&
  ! process_running_f 'wl-paste.*clipman store'; then
  wl-paste -t text --watch clipman store >/dev/null 2>&1 &
fi

if command -v salmon-display-profile-init >/dev/null 2>&1; then
  salmon-display-profile-init >/dev/null 2>&1 || true
fi

configure_hidpi_env() {
  [ "${SALMON_DESKTOP_AUTO_HIDPI:-1}" != "0" ] || return 0
  command -v wlr-randr >/dev/null 2>&1 || return 0
  if wlr-randr 2>/dev/null | awk '
    /^[[:space:]]*[0-9]+x[0-9]+ px,/ && /current/ {
      for (i = 1; i <= NF; i++) {
        if ($i ~ /^[0-9]+x[0-9]+$/) {
          split($i, d, "x")
          if ((d[1] + 0) >= 2560 && (d[2] + 0) >= 1440) found = 1
        }
      }
    }
    END { exit found ? 0 : 1 }
  '; then
    # Integer 2x output scaling is the least blurry HiDPI path on wlroots:
    # one logical pixel maps to a 2x2 physical block, and WebKitGTK/GTK apps
    # get a matching scale factor when launched from this session.
    export GDK_SCALE="${GDK_SCALE:-2}"
    [ "${GDK_SCALE}" = "1" ] && export GDK_SCALE=2
    export GDK_DPI_SCALE="${GDK_DPI_SCALE:-1}"
    [ "${GDK_DPI_SCALE}" = "1.5" ] && export GDK_DPI_SCALE=1
    export QT_SCALE_FACTOR="${QT_SCALE_FACTOR:-2}"
    export XCURSOR_SIZE="${XCURSOR_SIZE:-48}"
  fi
}
configure_hidpi_env

systemctl --user import-environment GDK_SCALE GDK_DPI_SCALE QT_SCALE_FACTOR XCURSOR_SIZE 2>/dev/null || true
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment --systemd GDK_SCALE GDK_DPI_SCALE QT_SCALE_FACTOR XCURSOR_SIZE 2>/dev/null || true
fi

if command -v kanshi >/dev/null 2>&1 && ! process_running kanshi; then
  if [ -r "$HOME/.config/salmon-desktop/kanshi" ]; then
    kanshi -c "$HOME/.config/salmon-desktop/kanshi" >/dev/null 2>&1 &
  elif [ -r "$HOME/.config/kanshi/config" ]; then
    kanshi >/dev/null 2>&1 &
  fi
fi

if process_running_f xdg-desktop-portal; then
  :
elif command -v /usr/libexec/xdg-desktop-portal >/dev/null 2>&1; then
  /usr/libexec/xdg-desktop-portal >/dev/null 2>&1 &
elif command -v /usr/lib/xdg-desktop-portal >/dev/null 2>&1; then
  /usr/lib/xdg-desktop-portal >/dev/null 2>&1 &
elif command -v xdg-desktop-portal >/dev/null 2>&1; then
  xdg-desktop-portal >/dev/null 2>&1 &
fi

if process_running mako || process_running dunst; then
  :
elif command -v mako >/dev/null 2>&1; then
  mako_config="${XDG_RUNTIME_DIR:-/tmp}/salmon-mako-config"
  if [ -r "$HOME/.config/mako/config" ]; then
    cp "$HOME/.config/mako/config" "$mako_config" 2>/dev/null || : > "$mako_config"
  else
    : > "$mako_config"
  fi
  if ! grep -q '^\[mode=do-not-disturb\]' "$mako_config" 2>/dev/null; then
    {
      printf '\n[mode=do-not-disturb]\n'
      printf 'invisible=1\n'
    } >> "$mako_config"
  fi
  mako -c "$mako_config" >/dev/null 2>&1 &
elif command -v dunst >/dev/null 2>&1; then
  dunst >/dev/null 2>&1 &
fi

if command -v waybar >/dev/null 2>&1 &&
  [ -r /usr/share/salmon-desktop/waybar/tray.jsonc ] &&
  ! process_running_f 'waybar.*salmon-desktop/waybar/tray.jsonc'; then
  waybar -c /usr/share/salmon-desktop/waybar/tray.jsonc -s /usr/share/salmon-desktop/waybar/tray.css >/dev/null 2>&1 &
fi

if polkit_agent_running; then
  :
elif command -v /usr/libexec/polkit-gnome-authentication-agent-1 >/dev/null 2>&1; then
  /usr/libexec/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 &
elif command -v /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1; then
  /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 &
elif command -v lxpolkit >/dev/null 2>&1; then
  lxpolkit >/dev/null 2>&1 &
elif command -v mate-polkit >/dev/null 2>&1; then
  mate-polkit >/dev/null 2>&1 &
fi

if command -v udiskie >/dev/null 2>&1 && ! process_running udiskie; then
  udiskie --no-tray --notify --file-manager xdg-open >/dev/null 2>&1 &
fi

if command -v swayidle >/dev/null 2>&1 && ! process_running swayidle; then
  swayidle -w \
    timeout 600 'salmon-session-action lock' \
    timeout 900 'sh -c "command -v wlopm >/dev/null 2>&1 && exec wlopm --off \"*\""' resume 'sh -c "command -v wlopm >/dev/null 2>&1 && exec wlopm --on \"*\""' \
    before-sleep 'salmon-session-action lock' \
    after-resume 'sh -c "command -v wlopm >/dev/null 2>&1 && exec wlopm --on \"*\""' \
    >/dev/null 2>&1 &
fi

while true; do
  /usr/bin/salmon-desktop
  code=$?
  [ "$code" -eq 0 ] && break
  sleep 2
done &
