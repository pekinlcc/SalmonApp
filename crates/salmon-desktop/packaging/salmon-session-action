#!/bin/sh
set -eu

action="${1:-}"

run_first() {
  last_status=1
  while [ "$#" -gt 0 ]; do
    if sh -c "$1"; then
      exit 0
    fi
    last_status=$?
    shift
  done
  exit "$last_status"
}

case "$action" in
  lock)
    # Prefer the Salmon-themed swaylock config when it's present
    # (installed by the .deb at /etc/salmon-desktop/swaylock.conf);
    # fall back to a solid-color invocation if the file was removed
    # locally or the user is testing the helper outside the package.
    salmon_swaylock_conf=/etc/salmon-desktop/swaylock.conf
    if [ -r "$salmon_swaylock_conf" ]; then
      swaylock_cmd="exec swaylock -f -C $salmon_swaylock_conf"
    else
      swaylock_cmd='exec swaylock -f -c 080a12'
    fi
    run_first \
      "command -v swaylock >/dev/null 2>&1 && $swaylock_cmd" \
      'command -v gtklock >/dev/null 2>&1 && exec gtklock' \
      'loginctl lock-session' \
      'xdg-screensaver lock'
    ;;
  suspend)
    run_first 'systemctl suspend' 'loginctl suspend'
    ;;
  reboot)
    run_first 'systemctl reboot' 'loginctl reboot'
    ;;
  poweroff)
    run_first 'systemctl poweroff' 'loginctl poweroff'
    ;;
  signout)
    if [ -n "${XDG_SESSION_ID:-}" ]; then
      loginctl terminate-session "$XDG_SESSION_ID" 2>/dev/null && exit 0
    fi
    if [ -n "${USER:-}" ]; then
      loginctl terminate-user "$USER"
    else
      printf 'Cannot sign out: USER is not set and XDG_SESSION_ID is unavailable\n' >&2
      exit 1
    fi
    ;;
  *)
    printf 'Usage: %s {lock|suspend|reboot|poweroff|signout}\n' "$0" >&2
    exit 64
    ;;
esac
