#!/bin/sh

fail=0
warn=0
root="${SALMON_DESKTOP_ROOT:-}"

ok() {
  printf 'OK   %s\n' "$1"
}

warning() {
  warn=$((warn + 1))
  printf 'WARN %s\n' "$1"
}

bad() {
  fail=$((fail + 1))
  printf 'FAIL %s\n' "$1"
}

need_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    ok "command: $1"
  elif [ -n "$root" ]; then
    warning "command not available in verifier host: $1"
  else
    bad "missing command: $1"
  fi
}

want_cmd() {
  if command -v "$1" >/dev/null 2>&1; then
    ok "command: $1"
  else
    warning "optional command not found: $1"
  fi
}

need_file() {
  if [ -e "$root$1" ]; then
    ok "file: $1"
  else
    bad "missing file: $1"
  fi
}

path_list_contains() {
  list="$1"
  expected="$2"
  old_ifs="$IFS"
  IFS=:
  # shellcheck disable=SC2086
  set -- $list
  IFS="$old_ifs"
  for item in "$@"; do
    while [ "${item%/}" != "$item" ]; do
      item="${item%/}"
    done
    if [ "$item" = "$expected" ]; then
      return 0
    fi
  done
  return 1
}

path_list_contains_suffix() {
  list="$1"
  suffix="$2"
  old_ifs="$IFS"
  IFS=:
  # shellcheck disable=SC2086
  set -- $list
  IFS="$old_ifs"
  for item in "$@"; do
    while [ "${item%/}" != "$item" ]; do
      item="${item%/}"
    done
    case "$item" in
      *"$suffix") return 0 ;;
    esac
  done
  return 1
}

want_any_cmd() {
  label="$1"
  shift
  for cmd in "$@"; do
    if command -v "$cmd" >/dev/null 2>&1; then
      ok "$label: $cmd"
      return
    fi
  done
  warning "$label not found: $*"
}

need_any_cmd() {
  label="$1"
  shift
  for cmd in "$@"; do
    if command -v "$cmd" >/dev/null 2>&1; then
      ok "$label: $cmd"
      return
    fi
  done
  if [ -n "$root" ]; then
    warning "$label not available in verifier host: $*"
  else
    bad "$label not found: $*"
  fi
}

need_gsettings_schema() {
  schema="$1"
  if ! command -v gsettings >/dev/null 2>&1; then
    if [ -n "$root" ]; then
      warning "gsettings schema not available in verifier host: $schema"
    else
      bad "missing gsettings command for schema: $schema"
    fi
    return
  fi
  if gsettings list-schemas 2>/dev/null | grep -qx "$schema"; then
    ok "gsettings schema: $schema"
  elif [ -n "$root" ]; then
    warning "gsettings schema not available in verifier host: $schema"
  else
    bad "missing gsettings schema: $schema"
  fi
}

process_running() {
  command -v pgrep >/dev/null 2>&1 && pgrep -x "$1" >/dev/null 2>&1
}

process_running_f() {
  command -v pgrep >/dev/null 2>&1 && pgrep -f "$1" >/dev/null 2>&1
}

need_process() {
  label="$1"
  shift
  for pattern in "$@"; do
    case "$pattern" in
      *" "*|*"/"*|*".*"*|*"|"*)
        if process_running_f "$pattern"; then
          ok "$label process: $pattern"
          return
        fi
        ;;
      *)
        if process_running "$pattern"; then
          ok "$label process: $pattern"
          return
        fi
        ;;
    esac
  done
  bad "$label process not running: $*"
}

want_process() {
  label="$1"
  shift
  for pattern in "$@"; do
    case "$pattern" in
      *" "*|*"/"*|*".*"*|*"|"*)
        if process_running_f "$pattern"; then
          ok "$label process: $pattern"
          return
        fi
        ;;
      *)
        if process_running "$pattern"; then
          ok "$label process: $pattern"
          return
        fi
        ;;
    esac
  done
  warning "$label process not running: $*"
}

in_salmon_session() {
  case ":${XDG_CURRENT_DESKTOP:-}:" in
    *:SalmonApp:*|*:wlroots:*) [ "${XDG_SESSION_TYPE:-}" = "wayland" ] ;;
    *) return 1 ;;
  esac
}

echo "SalmonApp Desktop doctor"
echo

need_file /usr/share/wayland-sessions/salmon-shell.desktop
need_file /usr/bin/salmon-session
need_file /usr/bin/salmon-desktop
need_file /usr/bin/salmon-screenshot
need_file /usr/bin/salmon-display-profile-init
need_file /usr/bin/salmon-input-toggle
need_file /usr/bin/salmon-open-browser
need_file /usr/bin/salmon-open-files
need_file /usr/bin/salmon-open-terminal
need_file /usr/bin/salmon-session-action
need_file /usr/share/salmon-desktop/labwc-config/autostart
need_file /usr/share/salmon-desktop/labwc-config/environment
need_file /usr/share/salmon-desktop/labwc-config/menu.xml
need_file /usr/share/salmon-desktop/labwc-config/rc.xml
need_file /usr/share/salmon-desktop/waybar/tray.jsonc
need_file /usr/share/salmon-desktop/waybar/tray.css
need_file /usr/share/xdg-desktop-portal/salmonapp-portals.conf
need_file /usr/share/xdg-desktop-portal/SalmonApp-portals.conf

session_desktop="$root/usr/share/wayland-sessions/salmon-shell.desktop"
if grep -q '^Name=SalmonApp Desktop$' "$session_desktop" \
  && grep -q '^Exec=/usr/bin/salmon-session$' "$session_desktop" \
  && grep -q '^TryExec=/usr/bin/salmon-session$' "$session_desktop" \
  && grep -q '^Type=Application$' "$session_desktop" \
  && grep -q '^DesktopNames=SalmonApp$' "$session_desktop"; then
  ok "wayland session desktop entry fields"
else
  bad "wayland session desktop entry fields are incomplete"
fi

session_launcher="$root/usr/bin/salmon-session"
if grep -q 'system_config="/usr/share/salmon-desktop/labwc-config"' "$session_launcher" \
  && grep -q 'exec labwc -C "$system_config"' "$session_launcher" \
  && grep -q 'XDG_CURRENT_DESKTOP=SalmonApp:wlroots' "$session_launcher" \
  && grep -q 'XDG_SESSION_TYPE=wayland' "$session_launcher"; then
  ok "session launcher starts labwc with Salmon desktop identity"
else
  bad "session launcher labwc identity is incomplete"
fi

if grep -q 'ensure_system_helper_path()' "$session_launcher" \
  && grep -q 'PATH="${PATH:+$PATH:}$d"' "$session_launcher" \
  && grep -q 'XDG_DATA_DIRS="/usr/local/share:/usr/share"' "$session_launcher" \
  && grep -q 'flatpak/exports/share' "$session_launcher" \
  && grep -q '/var/lib/snapd/desktop' "$session_launcher"; then
  ok "session launcher exports desktop discovery paths"
else
  bad "session launcher desktop discovery paths are incomplete"
fi

if grep -q 'GTK/Qt/XIM variables as a group' "$session_launcher" \
  && grep -q 'export GTK_IM_MODULE="${GTK_IM_MODULE:-fcitx}"' "$session_launcher" \
  && grep -q 'export QT_IM_MODULE="${QT_IM_MODULE:-fcitx}"' "$session_launcher" \
  && grep -q 'export XMODIFIERS="${XMODIFIERS:-@im=fcitx}"' "$session_launcher"; then
  ok "session launcher exports complete input method environment"
else
  bad "session launcher input method environment is incomplete"
fi

echo
need_cmd labwc
need_cmd Xwayland
need_cmd salmon-desktop
need_cmd salmon-display-profile-init
need_cmd salmon-input-toggle
need_cmd salmon-brightness
need_cmd salmon-open-browser
need_cmd salmon-open-files
need_cmd salmon-open-terminal
need_cmd salmon-session-action
need_cmd loginctl
need_cmd foot
need_cmd wlrctl
need_cmd wlr-randr
need_cmd waybar
need_cmd dbus-update-activation-environment
need_cmd xdg-open
need_cmd xdg-settings
need_cmd xdg-mime
need_cmd xdg-user-dir
need_cmd gio
need_cmd gtk-launch
need_any_cmd "xdg desktop portal service" /usr/libexec/xdg-desktop-portal /usr/lib/xdg-desktop-portal xdg-desktop-portal
need_any_cmd "xdg desktop portal gtk backend" /usr/libexec/xdg-desktop-portal-gtk /usr/lib/xdg-desktop-portal-gtk xdg-desktop-portal-gtk
need_any_cmd "xdg desktop portal wlr backend" /usr/libexec/xdg-desktop-portal-wlr /usr/lib/xdg-desktop-portal-wlr xdg-desktop-portal-wlr
need_cmd swaybg
need_cmd wl-copy
need_cmd wl-paste
need_cmd cliphist
need_cmd grim
need_cmd slurp
need_cmd lsblk
need_cmd udisksctl
need_cmd udiskie
need_cmd swayidle
need_cmd wlopm
need_cmd kanshi
need_cmd pgrep
need_cmd pkill
need_cmd swaylock
need_cmd brightnessctl
need_cmd gammastep
need_cmd playerctl
need_cmd powerprofilesctl
need_cmd notify-send
need_cmd bluetoothctl
need_cmd nmcli
need_cmd wpctl
need_cmd pactl
need_cmd lpstat
need_any_cmd "cups enable command" cupsenable /usr/sbin/cupsenable /sbin/cupsenable
need_any_cmd "cups disable command" cupsdisable /usr/sbin/cupsdisable /sbin/cupsdisable
need_any_cmd "cups cancel command" cancel /usr/bin/cancel /bin/cancel
need_cmd gsettings
need_cmd fc-list
need_gsettings_schema org.gnome.desktop.interface
need_gsettings_schema org.gnome.desktop.a11y.applications
need_gsettings_schema org.gnome.desktop.a11y.keyboard

echo
need_any_cmd "input method" fcitx5 ibus-daemon
need_any_cmd "input method switch command" fcitx5-remote ibus
need_any_cmd "input method settings" fcitx5-configtool fcitx5-config-qt ibus-setup gnome-control-center systemsettings xfce4-keyboard-settings cinnamon-settings
need_any_cmd "notification daemon" mako dunst
need_any_cmd "notification control" makoctl dunstctl
need_any_cmd "polkit agent" /usr/libexec/polkit-gnome-authentication-agent-1 /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 lxpolkit mate-polkit
if command -v cliphist >/dev/null 2>&1; then
  ok "optional clipboard fallback not needed because cliphist is available"
else
  want_cmd clipman
fi
want_any_cmd "sound settings" pavucontrol gnome-control-center systemsettings xfce4-mixer cinnamon-settings
want_any_cmd "trash backend" gio trash-put
want_any_cmd "file manager" nautilus thunar dolphin nemo
want_any_cmd "browser" firefox google-chrome chromium brave-browser microsoft-edge
want_any_cmd "system settings" gnome-control-center systemsettings xfce4-settings-manager lxqt-config mate-control-center cinnamon-settings
want_any_cmd "display settings" wdisplays gnome-control-center systemsettings xfce4-display-settings lxqt-config-monitor arandr cinnamon-settings
want_any_cmd "network settings" nm-connection-editor gnome-control-center systemsettings cinnamon-settings
want_any_cmd "printer settings" system-config-printer gnome-control-center systemsettings cinnamon-settings
want_any_cmd "power settings" gnome-control-center systemsettings xfce4-power-manager-settings mate-power-preferences cinnamon-settings
want_any_cmd "date/time settings" gnome-control-center systemsettings time-admin mate-time-admin cinnamon-settings
want_any_cmd "accessibility settings" gnome-control-center systemsettings xfce4-accessibility-settings mate-at-properties cinnamon-settings
want_any_cmd "system info" gnome-control-center kinfocenter hardinfo hardinfo2 neofetch

echo
if [ -n "${XDG_CURRENT_DESKTOP:-}" ]; then
  case ":$XDG_CURRENT_DESKTOP:" in
    *:SalmonApp:*|*:wlroots:*) ok "XDG_CURRENT_DESKTOP=$XDG_CURRENT_DESKTOP" ;;
    *) warning "XDG_CURRENT_DESKTOP is not SalmonApp/wlroots: $XDG_CURRENT_DESKTOP" ;;
  esac
else
  warning "XDG_CURRENT_DESKTOP is not set"
fi

if [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
  ok "XDG_SESSION_TYPE=wayland"
else
  warning "XDG_SESSION_TYPE is not wayland: ${XDG_SESSION_TYPE:-unset}"
fi

if [ -n "${WAYLAND_DISPLAY:-}" ]; then
  ok "WAYLAND_DISPLAY=$WAYLAND_DISPLAY"
else
  warning "WAYLAND_DISPLAY is not set"
fi

if [ -n "${XDG_DATA_DIRS:-}" ]; then
  if path_list_contains "$XDG_DATA_DIRS" "/usr/share"; then
    ok "XDG_DATA_DIRS includes /usr/share"
  else
    warning "XDG_DATA_DIRS does not include /usr/share: $XDG_DATA_DIRS"
  fi
  if [ -d "$HOME/.local/share/flatpak/exports/share" ] || [ -d /var/lib/flatpak/exports/share ]; then
    if path_list_contains_suffix "$XDG_DATA_DIRS" "/flatpak/exports/share"; then
      ok "XDG_DATA_DIRS includes Flatpak exports"
    else
      warning "XDG_DATA_DIRS is missing Flatpak exports: $XDG_DATA_DIRS"
    fi
  fi
  if [ -d /var/lib/snapd/desktop ]; then
    if path_list_contains "$XDG_DATA_DIRS" "/var/lib/snapd/desktop"; then
      ok "XDG_DATA_DIRS includes Snap desktop exports"
    else
      warning "XDG_DATA_DIRS is missing Snap desktop exports: $XDG_DATA_DIRS"
    fi
  fi
else
  warning "XDG_DATA_DIRS is not set"
fi

if [ -n "${XDG_CONFIG_DIRS:-}" ]; then
  ok "XDG_CONFIG_DIRS=$XDG_CONFIG_DIRS"
else
  warning "XDG_CONFIG_DIRS is not set"
fi

case ":${PATH:-}:" in
  *:/usr/sbin:*|*:/sbin:*)
    ok "PATH includes system sbin directories"
    ;;
  *)
    warning "PATH does not include /usr/sbin or /sbin; some desktop management helpers may be hidden"
    ;;
esac

case "${GTK_IM_MODULE:-}:${QT_IM_MODULE:-}:${XMODIFIERS:-}" in
  fcitx:fcitx:@im=fcitx|ibus:ibus:@im=ibus)
    ok "input env: GTK_IM_MODULE=${GTK_IM_MODULE:-unset} QT_IM_MODULE=${QT_IM_MODULE:-unset} XMODIFIERS=${XMODIFIERS:-unset}"
    ;;
  ::)
    warning "input method environment is not set"
    ;;
  *)
    bad "input method environment is incomplete: GTK_IM_MODULE=${GTK_IM_MODULE:-unset} QT_IM_MODULE=${QT_IM_MODULE:-unset} XMODIFIERS=${XMODIFIERS:-unset}"
    ;;
esac

if in_salmon_session; then
  echo
  ok "running inside SalmonApp Desktop session"
  need_process "compositor" labwc
  need_process "Salmon shell" salmonapp-desktop salmon-desktop
  need_process "portal service" xdg-desktop-portal
  need_process "portal wlr backend" xdg-desktop-portal-wlr
  need_process "notification daemon" mako dunst
  need_process "tray host" 'waybar.*salmon-desktop/waybar/tray.jsonc'
  need_process "clipboard history watcher" 'wl-paste.*cliphist store' 'wl-paste.*clipman store'
  need_process "polkit agent" polkit-gnome-authentication-agent-1 lxpolkit mate-polkit
  need_process "removable media helper" udiskie
  need_process "idle manager" swayidle
  want_process "background helper" swaybg
  want_process "input method daemon" fcitx5 ibus-daemon
  if [ -r "$HOME/.config/salmon-desktop/kanshi" ] || [ -r "$HOME/.config/kanshi/config" ]; then
    need_process "display profile helper" kanshi
  else
    warning "runtime kanshi process is pending first-layout seeding"
  fi
else
  warning "runtime process checks skipped; not currently inside SalmonApp Desktop"
fi

if [ -r "$HOME/.config/salmon-desktop/kanshi" ]; then
  ok "kanshi config: ~/.config/salmon-desktop/kanshi"
elif [ -r "$HOME/.config/kanshi/config" ]; then
  ok "kanshi config: ~/.config/kanshi/config"
elif command -v salmon-display-profile-init >/dev/null 2>&1; then
  warning "no kanshi config found yet; Salmon will seed the current layout on first wlroots session start"
else
  warning "no kanshi config found; hotplug display profiles are not configured"
fi

if command -v python3 >/dev/null 2>&1; then
  if SALMON_DESKTOP_ROOT="$root" python3 - <<'PY' >/dev/null 2>&1
import os
import xml.etree.ElementTree as ET

ET.parse(os.environ.get("SALMON_DESKTOP_ROOT", "") + "/usr/share/salmon-desktop/labwc-config/rc.xml")
ET.parse(os.environ.get("SALMON_DESKTOP_ROOT", "") + "/usr/share/salmon-desktop/labwc-config/menu.xml")
PY
  then
    ok "labwc rc.xml and menu.xml parse"
  else
    bad "labwc rc.xml or menu.xml does not parse"
  fi
else
  warning "python3 not found; skipped labwc XML parse"
fi

autostart="$root/usr/share/salmon-desktop/labwc-config/autostart"
if grep -q 'dbus-update-activation-environment --systemd PATH DISPLAY WAYLAND_DISPLAY' "$autostart" \
  && grep -q 'XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE DESKTOP_SESSION' "$autostart" \
  && grep -q 'XDG_DATA_DIRS XDG_CONFIG_DIRS' "$autostart"; then
  ok "autostart imports desktop environment into dbus/systemd"
else
  bad "autostart desktop environment import is incomplete"
fi

if grep -q '! process_running fcitx5' "$autostart" \
  && grep -q '! process_running swaybg' "$autostart" \
  && grep -q 'wl-paste.*cliphist store' "$autostart" \
  && grep -q 'salmon-display-profile-init' "$autostart" \
  && grep -q '! process_running kanshi' "$autostart" \
  && grep -q 'process_running_f xdg-desktop-portal' "$autostart"; then
  ok "autostart session services are guarded against duplicates"
else
  bad "autostart duplicate guards are incomplete"
fi

if grep -q 'process_running mako || process_running dunst' "$autostart" \
  && grep -q '\[mode=do-not-disturb\]' "$autostart" \
  && grep -q 'waybar.*salmon-desktop/waybar/tray.jsonc' "$autostart" \
  && grep -q 'salmon-display-profile-init' "$autostart" \
  && grep -q 'polkit_agent_running' "$autostart" \
  && grep -q '! process_running udiskie' "$autostart" \
  && grep -q '! process_running swayidle' "$autostart"; then
  ok "autostart desktop baseline daemons"
else
  bad "autostart desktop baseline daemons are incomplete"
fi

rc_xml="$root/usr/share/salmon-desktop/labwc-config/rc.xml"
if grep -q '<desktops number="4">' "$rc_xml" \
  && grep -q 'name="GoToDesktop" to="1"' "$rc_xml" \
  && grep -q 'name="SendToDesktop" to="1"' "$rc_xml" \
  && grep -q 'name="SnapToEdge" direction="left"' "$rc_xml" \
  && grep -q 'name="ToggleShowDesktop"' "$rc_xml" \
  && grep -q 'key="A-F4"' "$rc_xml"; then
  ok "workspace and window shortcut bindings"
else
  bad "workspace and window shortcut bindings are incomplete"
fi

if grep -q 'key="XF86AudioMicMute"' "$rc_xml" \
  && grep -q 'key="XF86AudioPlay"' "$rc_xml" \
  && grep -q 'key="XF86AudioNext"' "$rc_xml" \
  && grep -q 'key="C-A-t"' "$rc_xml" \
  && grep -q 'wpctl set-volume -l 1.5' "$rc_xml" \
  && grep -q 'pactl set-sink-volume @DEFAULT_SINK@ +5%' "$rc_xml" \
  && grep -q 'salmon-brightness up' "$rc_xml" \
  && grep -q 'salmon-brightness down' "$rc_xml"; then
  ok "hardware media and terminal shortcut bindings"
else
  bad "hardware media or terminal shortcut bindings are incomplete"
fi

menu_xml="$root/usr/share/salmon-desktop/labwc-config/menu.xml"
if grep -q 'menu="root-menu"' "$rc_xml" \
  && grep -q '<menu id="root-menu">' "$menu_xml" \
  && grep -q '<menu id="client-menu">' "$menu_xml"; then
  ok "root and client fallback menus"
else
  bad "root and client fallback menus are incomplete"
fi

tray_json="$root/usr/share/salmon-desktop/waybar/tray.jsonc"
tray_css="$root/usr/share/salmon-desktop/waybar/tray.css"
if grep -q '"modules-right": \["tray"\]' "$tray_json" \
  && grep -q '"show-passive-items": true' "$tray_json" \
  && grep -q '#tray' "$tray_css"; then
  ok "tray-only Waybar host config"
else
  bad "tray-only Waybar host config is incomplete"
fi

portal_conf="$root/usr/share/xdg-desktop-portal/salmonapp-portals.conf"
if [ -f "$portal_conf" ]; then
  if grep -q '^default=wlr;gtk;$' "$portal_conf" \
    && grep -q '^org.freedesktop.impl.portal.ScreenCast=wlr;$' "$portal_conf" \
    && grep -q '^org.freedesktop.impl.portal.RemoteDesktop=wlr;$' "$portal_conf" \
    && grep -q '^org.freedesktop.impl.portal.FileChooser=gtk;$' "$portal_conf" \
    && grep -q '^org.freedesktop.impl.portal.Settings=gtk;$' "$portal_conf"; then
    ok "salmonapp portal preferences"
  else
    bad "salmonapp portal preferences are incomplete"
  fi
fi
portal_case_conf="$root/usr/share/xdg-desktop-portal/SalmonApp-portals.conf"
if [ -f "$portal_conf" ] && [ -f "$portal_case_conf" ]; then
  if cmp -s "$portal_conf" "$portal_case_conf"; then
    ok "SalmonApp portal preference case alias"
  else
    bad "SalmonApp portal preference case alias differs"
  fi
fi

echo
if [ "$fail" -eq 0 ]; then
  echo "Result: pass with $warn warning(s)"
  exit 0
fi

echo "Result: fail with $fail failure(s), $warn warning(s)"
exit 1
