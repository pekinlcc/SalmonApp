#!/bin/sh
set -eu

if [ -n "${BROWSER:-}" ]; then
  # Respect the user's explicit browser preference. This intentionally uses
  # shell word splitting so values like "firefox --new-window" keep working.
  # shellcheck disable=SC2086
  set -- $BROWSER
  if [ "$#" -gt 0 ] && command -v "$1" >/dev/null 2>&1; then
    exec "$@"
  fi
fi

if command -v xdg-settings >/dev/null 2>&1 && command -v gtk-launch >/dev/null 2>&1; then
  default_browser="$(xdg-settings get default-web-browser 2>/dev/null || true)"
  if [ -n "$default_browser" ]; then
    gtk-launch "$default_browser" >/dev/null 2>&1 && exit 0
  fi
fi

for browser in x-www-browser firefox google-chrome chromium brave-browser microsoft-edge; do
  if command -v "$browser" >/dev/null 2>&1; then
    exec "$browser"
  fi
done

exec xdg-open https://example.com
