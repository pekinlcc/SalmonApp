#!/bin/sh

set -eu

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/salmon-desktop"
config_file="$config_dir/kanshi"
fallback_config="${XDG_CONFIG_HOME:-$HOME/.config}/kanshi/config"

if [ -s "$config_file" ] || [ -s "$fallback_config" ]; then
  exit 0
fi

command -v wlr-randr >/dev/null 2>&1 || exit 0

tmp="$(mktemp "${TMPDIR:-/tmp}/salmon-kanshi.XXXXXX")"
cleanup() {
  rm -f "$tmp"
}
trap cleanup EXIT

if ! wlr-randr 2>/dev/null | awk '
function trim(s) {
  sub(/^[[:space:]]+/, "", s)
  sub(/[[:space:]]+$/, "", s)
  return s
}

function quote(s, q) {
  q = s
  gsub(/\\/, "\\\\", q)
  gsub(/"/, "\\\"", q)
  return "\"" q "\""
}

function flush() {
  if (name != "" && enabled == "yes") {
    if (ENVIRON["SALMON_DESKTOP_AUTO_HIDPI"] != "0" &&
        (scale == "" || scale == "1" || scale == "1.0") &&
        mode_w >= 2560 && mode_h >= 1440) {
      scale = "2"
    }
    line = "  output " quote(name) " enable"
    if (mode != "") {
      line = line " mode " mode
    }
    if (position != "") {
      line = line " position " position
    }
    if (scale != "") {
      line = line " scale " scale
    }
    if (transform != "") {
      line = line " transform " transform
    }
    print line
    count++
  }
  name = ""
  enabled = ""
  mode = ""
  position = ""
  scale = ""
  transform = ""
  mode_w = 0
  mode_h = 0
}

BEGIN {
  print "# Generated by salmon-display-profile-init."
  print "# Salmon Desktop owns this file; use the display profile UI for later changes."
  print "profile salmon-current {"
}

/^[^[:space:]]/ {
  flush()
  name = $1
  next
}

/^[[:space:]]*Enabled:/ {
  enabled = trim(substr($0, index($0, ":") + 1))
  next
}

/^[[:space:]]*[0-9]+x[0-9]+ px,/ && /current/ {
  size = ""
  rate = ""
  for (i = 1; i <= NF; i++) {
    if ($i ~ /^[0-9]+x[0-9]+$/) {
      size = $i
    } else if ($i == "Hz" && i > 1 && $(i - 1) ~ /^[0-9]+(\.[0-9]+)?$/) {
      rate = $(i - 1)
    }
  }
  if (size != "" && rate != "") {
    mode = size "@" rate "Hz"
  } else if (size != "") {
    mode = size
  }
  if (size != "") {
    split(size, dims, "x")
    mode_w = dims[1] + 0
    mode_h = dims[2] + 0
  }
  next
}

/^[[:space:]]*Position:/ {
  value = trim(substr($0, index($0, ":") + 1))
  if (value ~ /^-?[0-9]+,-?[0-9]+$/) {
    position = value
  }
  next
}

/^[[:space:]]*Scale:/ {
  value = trim(substr($0, index($0, ":") + 1))
  if (value ~ /^[0-9]+(\.[0-9]+)?$/) {
    scale = value
  }
  next
}

/^[[:space:]]*Transform:/ {
  value = trim(substr($0, index($0, ":") + 1))
  if (value ~ /^(normal|90|180|270|flipped|flipped-90|flipped-180|flipped-270)$/) {
    transform = value
  }
  next
}

END {
  flush()
  print "}"
  if (count == 0) {
    exit 1
  }
}
' > "$tmp"; then
  exit 0
fi

mkdir -p "$config_dir"
chmod 0700 "$config_dir"
install -m 0644 "$tmp" "$config_file"
