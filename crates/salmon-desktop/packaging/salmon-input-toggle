#!/bin/sh
set -eu

if command -v fcitx5-remote >/dev/null 2>&1; then
  exec fcitx5-remote -t
fi

if command -v ibus >/dev/null 2>&1; then
  current="$(ibus engine 2>/dev/null || true)"
  engines="$(ibus list-engine 2>/dev/null || true)"
  first_non_xkb="$(
    printf '%s\n' "$engines" \
      | awk '/^[[:space:]]*[A-Za-z0-9_.:@-]+[[:space:]]+-/ { print $1 }' \
      | awk '$0 !~ /^xkb:/ { print; exit }'
  )"
  first_xkb="$(
    printf '%s\n' "$engines" \
      | awk '/^[[:space:]]*[A-Za-z0-9_.:@-]+[[:space:]]+-/ { print $1 }' \
      | awk '$0 ~ /^xkb:/ { print; exit }'
  )"
  if [ -n "$current" ] && [ "${current#xkb:}" != "$current" ]; then
    if [ -n "$first_non_xkb" ]; then
      exec ibus engine "$first_non_xkb"
    fi
  fi
  if [ -n "$first_xkb" ]; then
    exec ibus engine "$first_xkb"
  fi
  exec ibus engine xkb:us::eng
fi

exit 1
