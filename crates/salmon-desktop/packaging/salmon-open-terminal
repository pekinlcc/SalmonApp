#!/bin/sh
set -eu

command_mode=0
if [ "$#" -gt 0 ]; then
  command_mode=1
fi

run_terminal_command() {
  terminal="$1"
  shift
  case "$terminal" in
    gnome-terminal) exec "$terminal" -- "$@" ;;
    wezterm) exec "$terminal" start -- "$@" ;;
    kitty) exec "$terminal" "$@" ;;
    *) exec "$terminal" -e "$@" ;;
  esac
}

if [ -n "${TERMINAL:-}" ]; then
  if [ "$command_mode" -eq 1 ]; then
    case "$TERMINAL" in
      *" "*|*"	"*) ;;
      *)
        if command -v "$TERMINAL" >/dev/null 2>&1; then
          run_terminal_command "$TERMINAL" "$@"
        fi
        ;;
    esac
  else
    # Respect explicit user preference. Word splitting keeps values like
    # "alacritty --working-directory /tmp" usable for opening a blank terminal.
    # shellcheck disable=SC2086
    set -- $TERMINAL
    if [ "$#" -gt 0 ] && command -v "$1" >/dev/null 2>&1; then
      exec "$@"
    fi
  fi
fi

for terminal in x-terminal-emulator foot gnome-terminal konsole alacritty kitty wezterm xfce4-terminal xterm; do
  if command -v "$terminal" >/dev/null 2>&1; then
    if [ "$command_mode" -eq 1 ]; then
      run_terminal_command "$terminal" "$@"
    fi
    exec "$terminal"
  fi
done

printf 'No terminal emulator found\n' >&2
exit 1
